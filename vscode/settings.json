{
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers",
  },
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.insertFinalNewline": true,
  "files.associations": {
    "*.json": "jsonc",
    "*.brewfile": "pip-requirements",
    "*.yaml.template": "yaml",
  },
  "gitlens.blame.dateFormat": "YYYY-MM-DD",
  "gitlens.currentLine.dateFormat": "YYYY-MM-DD",
  "gitlens.defaultDateFormat": "YYYY-MM-DD hh:mm:ss",
  "gitlens.defaultDateShortFormat": "YYYY-MM-DD",
  "gitlens.hovers.enabled": false,
  "gitlens.statusBar.dateFormat": "YYYY-MM-DD",
  "path-intellisense.showHiddenFiles": true,
  "prettier.printWidth": 120,
  "[python]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit",
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "python.defaultInterpreterPath": "python3",
  "python.testing.unittestEnabled": true,
  "python.languageServer": "Pylance",
  "python.experiments.enabled": false,
  "python.interpreter.infoVisibility": "always",
  "ruff.interpreter": [
    "python3"
  ],
  "ruff.path": [
    "~/.local/bin/ruff"
  ],
  "shellcheck.customArgs": [
    "-e SC1071"
  ],
  "terminal.integrated.defaultProfile.osx": "zsh",
  "workbench.colorTheme": "An Old Hope Classic",
  "workbench.iconTheme": "material-icon-theme",
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
  },
  "github.gitAuthentication": false,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "gitlens.codeLens.enabled": false,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true,
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.guides.bracketPairs": true,
  "telemetry.telemetryLevel": "off",
  "editor.renderWhitespace": "none",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.inlineSuggest.enabled": true,
  "terminal.integrated.shellIntegration.enabled": true,
  "workbench.startupEditor": "none",
  "terminal.explorerKind": "external",
  "terminal.integrated.shellIntegration.history": 10000,
  "terminal.integrated.scrollback": 100000,
  "editor.fontFamily": "'MesloLGS NF', 'Hack Nerd Font Mono', 'Hack Nerd Font', Menlo, Monaco, 'Courier New', monospace",
  "editor.codeLensFontFamily": "'Hack Nerd Font Mono', 'Hack Nerd Font', Menlo, Monaco, 'Courier New', monospace",
  "github.copilot.editor.enableAutoCompletions": true,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "github.copilot.chat.welcomeMessage": "always",
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "diffEditor.ignoreTrimWhitespace": false,
  },
  "chat.agent.enabled": true,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": true,
  "gitlens.blame.toggleMode": "window",
  "docker.extension.enableComposeLanguageServer": false,
  "go.toolsManagement.autoUpdate": true,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true,
    },
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1",
  "gitlens.views.scm.grouped.views": {
    "commits": true,
    "branches": true,
    "remotes": true,
    "stashes": true,
    "tags": true,
    "worktrees": true,
    "contributors": true,
    "fileHistory": false,
    "repositories": true,
    "searchAndCompare": true,
    "launchpad": false,
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "chat.agent.maxRequests": 125,
  "chat.mcp.gallery.enabled": true,
}
