{
  "$schema": "vscode://schemas/settings/user",
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers",
  },
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "files.insertFinalNewline": true,
  "files.associations": {
    "*.json": "jsonc",
    "*.brewfile": "pip-requirements",
    "*.yaml.template": "yaml",
  },
  "path-intellisense.showHiddenFiles": true,
  "prettier.printWidth": 120,
  "[python]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit",
    },
    "editor.defaultFormatter": "charliermarsh.ruff",
  },
  "python.defaultInterpreterPath": "python3",
  "python.testing.unittestEnabled": true,
  "python.languageServer": "Pylance",
  "python.experiments.enabled": false,
  "python.interpreter.infoVisibility": "always",
  "ruff.interpreter": ["python3"],
  "ruff.path": ["~/.local/bin/ruff"],
  "shellcheck.customArgs": ["-e SC1071"],
  "terminal.integrated.defaultProfile.osx": "zsh",
  "workbench.colorTheme": "An Old Hope Classic",
  "workbench.iconTheme": "material-icon-theme",
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
  },
  "github.gitAuthentication": false,
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true,
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.guides.bracketPairs": true,
  "telemetry.telemetryLevel": "off",
  "editor.renderWhitespace": "none",
  "workbench.settings.enableNaturalLanguageSearch": false,
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.inlineSuggest.enabled": true,
  "terminal.integrated.shellIntegration.enabled": true,
  "workbench.startupEditor": "none",
  "terminal.explorerKind": "external",
  "terminal.integrated.shellIntegration.history": 10000,
  "terminal.integrated.scrollback": 100000,
  "editor.fontFamily": "'Hack Nerd Font Mono', 'Hack Nerd Font', Menlo, Monaco, 'Courier New', monospace",
  "editor.codeLensFontFamily": "'Hack Nerd Font Mono', 'Hack Nerd Font', Menlo, Monaco, 'Courier New', monospace",
  "github.copilot.editor.enableAutoCompletions": true,
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "github.copilot.chat.welcomeMessage": "always",
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "diffEditor.ignoreTrimWhitespace": false,
  },
  "chat.agent.enabled": true,
  "git.blame.editorDecoration.enabled": true,
  "git.blame.statusBarItem.enabled": true,
  "git.addAICoAuthor": "off",
  "docker.extension.enableComposeLanguageServer": false,
  "go.toolsManagement.autoUpdate": true,
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.quickSuggestions": {
      "other": true,
      "comments": false,
      "strings": true,
    },
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "chat.agent.maxRequests": 125,
  "chat.mcp.gallery.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "python.analysis.referencesCodeLens": true,
  "chat.tools.terminal.autoApprove": {
    "/^uv run poe pyright$/": {
      "approve": true,
      "matchCommandLine": true,
    },
    "/^uv run poe check_type$/": {
      "approve": true,
      "matchCommandLine": true,
    },
  },
  "chat.experimental.incrementalRendering.enabled": true,
  "workbench.diffEditorAssociations": {
    "*.md": "vscode.markdown.preview.editor",
  },
  "chat.tools.compressOutput.enabled": true,
  "remote.autoForwardPortsSource": "hybrid",
  "pythonOverrideMark.display.gutterIcons": true
}
