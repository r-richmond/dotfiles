#!/usr/bin/env bash
#
# Run all dotfiles installers.

set -e

DOTFILES="${DOTFILES:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)}"
export DOTFILES

# Ask for the administrator password upfront
if command -v sudo >/dev/null 2>&1; then
  sudo -v
fi

cd "$DOTFILES"

run_installers() {
  local installer

  while IFS= read -r -d '' installer; do
    printf ' running %s\n' "$installer"
    bash "$installer"
  done < <(find . "$@" -type f -name install.sh -print0)
}

# run homebrew first
bash ./homebrew/install.sh

if [ "$(uname -s)" != "Darwin" ]; then
  echo "Running install.sh except ./macos/*"
  run_installers ! -path './macos/*' ! -path './homebrew/*'
else
  echo "Running install.sh including ./macos/*"
  run_installers ! -path './homebrew/*'
fi
