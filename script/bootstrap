#!/usr/bin/env bash
#
# bootstrap installs things.

set -e

# Resolve DOTFILES when the caller hasn't exported it already.
DOTFILES="${DOTFILES:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)}"
export DOTFILES

overwrite_all=false
backup_all=false
absorb_all=false
skip_all=false

echo ''

if [ ! -d "$DOTFILES" ]; then
  printf "\r\033[2K  [\033[0;31mFAIL\033[0m] %s\n" "DOTFILES not found: $DOTFILES" >&2
  echo '' >&2
  exit 1
fi

source "$DOTFILES/script/lib/ui"
source "$DOTFILES/script/lib/symlink"

if [ "$(uname -s)" != "Darwin" ]; then
  fail 'script/bootstrap only supports macOS'
fi

cd "$DOTFILES"

setup_gitconfig() {
  local local_git_config="$HOME"/dropbox/config/dotfiles/git/symlink.gitconfig.local

  if [ -f "$local_git_config" ] && ! [ -f "$HOME"/.gitconfig.local ]; then
    local src="$local_git_config"
    local dst="$HOME"/.gitconfig.local
    link_file "$src" "$dst"
    success "Linked personal $src to $dst"
  fi

  if ! [ -f git/symlink.gitconfig.local ] && ! [ -f ~/.gitconfig.local ]; then
    info 'setup gitconfig'

    local git_credential='cache'
    if [ "$(uname -s)" = "Darwin" ]; then
      git_credential='osxkeychain'
    fi

    user ' - What is your github author name?'
    read -r -e git_authorname
    user ' - What is your github author email?'
    read -r -e git_authoremail

    if ! [ -f git/example.symlink.gitconfig.local ]; then
      fail 'missing git/example.symlink.gitconfig.local'
    fi

    sed -e "s/AUTHORNAME/$git_authorname/g" -e "s/AUTHOREMAIL/$git_authoremail/g" -e "s/GIT_CREDENTIAL_HELPER/$git_credential/g" git/example.symlink.gitconfig.local >git/symlink.gitconfig.local

    success 'gitconfig'
  fi
}

backup_file() {
  local dst=$1 print=$2
  local backup_root="$HOME/backup-dot-files"
  local backup_path="$backup_root$dst"
  local backup_dir

  backup_dir=$(dirname "$backup_path")
  mkdir -p "$backup_dir"

  if [ -e "$backup_path" ] || [ -L "$backup_path" ]; then
    backup_path="$backup_path.$(date +%Y%m%d%H%M%S)"
  fi

  mv "$dst" "$backup_path"

  if [ "$print" = "true" ]; then
    success "moved $dst to $backup_path"
  fi
}

run_dot_installs() {
  bin/dot
}

find_zsh() {
  local candidate

  for candidate in /opt/homebrew/bin/zsh /usr/local/bin/zsh /usr/bin/zsh; do
    if [ -x "$candidate" ]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

ensure_login_shell() {
  local target_shell=$1
  local current_shell

  current_shell=$(dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}')

  if [ "$current_shell" = "$target_shell" ]; then
    success "login shell already set to $target_shell"
    return 0
  fi

  info "changing shell to $target_shell"
  sudo dscl . -create "/Users/$USER" UserShell "$target_shell"
  success "All new sessions will use $target_shell"
}

link_file() {
  local src=$1 dst=$2

  local overwrite=
  local backup=
  local absorb=
  local skip=
  local action=
  local allow_absorb=false

  # check if target exists and is symlink
  if [ -e "$dst" ] || [ -L "$dst" ]; then

    if [ "$overwrite_all" != "true" ] && [ "$backup_all" != "true" ] && [ "$absorb_all" != "true" ] && [ "$skip_all" != "true" ]; then

      local current_src=''
      local resolved_current_src=''
      local resolved_src

      resolved_src=$(resolve_path "$src")

      if [ -L "$dst" ]; then
        current_src="$(readlink "$dst")"
        resolved_current_src=$(resolve_link_target "$dst" 2>/dev/null || true)
      fi

      if [ "$current_src" = "$src" ] || { [ -n "$resolved_current_src" ] && [ "$resolved_current_src" = "$resolved_src" ]; }; then

        skip=true

      else
        if [ -f "$src" ] && [ -f "$dst" ]; then
          allow_absorb=true
        fi

        while true; do
          if [ "$allow_absorb" = "true" ]; then
            user "Path already exists: $dst ($(basename "$src")), what do you want to do?\n\
          [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [a]bsorb, [A]bsorb all, [b]ackup, [B]ackup all?"
          else
            user "Path already exists: $dst ($(basename "$src")), what do you want to do?\n\
          [s]kip, [S]kip all, [o]verwrite, [O]verwrite all, [b]ackup, [B]ackup all?"
          fi

          if ! read -r -n 1 action; then
            echo ''
            fail "unable to read a response for $dst"
          fi

          echo ''

          case "$action" in
          o)
            overwrite=true
            break
            ;;
          O)
            overwrite_all=true
            break
            ;;
          b)
            backup=true
            break
            ;;
          B)
            backup_all=true
            break
            ;;
          a)
            if [ "$allow_absorb" = "true" ]; then
              absorb=true
              break
            fi
            ;;
          A)
            if [ "$allow_absorb" = "true" ]; then
              absorb_all=true
              break
            fi
            ;;
          s)
            skip=true
            break
            ;;
          S)
            skip_all=true
            break
            ;;
          *)
            user "invalid choice: $action"
            ;;
          esac
        done

      fi

    fi

    overwrite=${overwrite:-$overwrite_all}
    backup=${backup:-$backup_all}
    skip=${skip:-$skip_all}
    absorb=${absorb:-$absorb_all}

    if [ "$overwrite" = "true" ]; then
      rm -rf "$dst"
      success "removed $dst"
    fi

    if [ "$backup" = "true" ]; then
      backup_file "$dst" "true"
    fi

    if [ "$absorb" = "true" ]; then
      local absorbed_src

      if ! [ -f "$src" ] || ! [ -f "$dst" ]; then
        fail "absorb is only supported for regular files: $dst"
      fi

      absorbed_src=$(mktemp "${src}.XXXXXX")
      cat "$dst" >"$absorbed_src"
      mv "$absorbed_src" "$src"
      backup_file "$dst" "false"
      success "review changes in git - absorbed $dst to $src"
    fi

    if [ "$skip" = "true" ]; then
      success "skipped $src"
    fi
  fi

  if [ "$skip" != "true" ]; then
    link_symlink "$src" "$dst"
    success "linked $src to $dst"
  fi
}

install_dotfiles() {
  info 'installing dotfiles'

  local src dst

  while IFS= read -r -d '' src; do
    dst=$(symlink_destination_for "$src") || fail "invalid symlink source: $src"
    link_file "$src" "$dst"
  done < <(find_symlink_sources)
}

setup_gitconfig
install_dotfiles

# Lets run install files
if run_dot_installs; then
  success "dependencies installs"
else
  fail "error installing dependencies"
fi

# If we're on a Mac, let's install and setup homebrew.
if [ "$(uname -s)" = "Darwin" ]; then
  info "Running on mac"
fi

if zsh_path=$(find_zsh); then
  ensure_login_shell "$zsh_path"
else
  fail 'zsh not found in standard locations'
fi

echo ''
success '  All installed!'
