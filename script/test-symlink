#!/usr/bin/env bash

set -e

DOTFILES="${DOTFILES:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)}"
export DOTFILES

if [ ! -d "$DOTFILES" ]; then
  printf 'DOTFILES not found: %s\n' "$DOTFILES" >&2
  exit 1
fi

source "$DOTFILES/script/lib/symlink"

ok_count=0
missing_count=0
mismatch_count=0
broken_count=0
invalid_count=0

while IFS= read -r -d '' src; do
  expected_src=$(resolve_path "$src")
  dst=$(symlink_destination_for "$src") || {
    printf 'INVALID  %s\n' "$src"
    invalid_count=$((invalid_count + 1))
    continue
  }

  if [ ! -L "$dst" ]; then
    printf 'MISSING  %s -> %s\n' "$src" "$dst"
    missing_count=$((missing_count + 1))
    continue
  fi

  current_src=$(readlink "$dst")
  resolved_current_src=$(resolve_link_target "$dst" 2>/dev/null || true)
  if [ "$current_src" = "$src" ] || { [ -n "$resolved_current_src" ] && [ "$resolved_current_src" = "$expected_src" ]; }; then
    printf 'OK       %s -> %s\n' "$src" "$dst"
    ok_count=$((ok_count + 1))
    continue
  fi

  if [ -e "$dst" ]; then
    printf 'MISMATCH %s -> %s (actual: %s)\n' "$src" "$dst" "$current_src"
    mismatch_count=$((mismatch_count + 1))
  else
    printf 'BROKEN   %s -> %s (actual: %s)\n' "$src" "$dst" "$current_src"
    broken_count=$((broken_count + 1))
  fi
done < <(find_symlink_sources)

printf '\nSummary: ok=%s missing=%s mismatch=%s broken=%s invalid=%s\n' \
  "$ok_count" \
  "$missing_count" \
  "$mismatch_count" \
  "$broken_count" \
  "$invalid_count"

if [ "$missing_count" -gt 0 ] || [ "$mismatch_count" -gt 0 ] || [ "$broken_count" -gt 0 ] || [ "$invalid_count" -gt 0 ]; then
  exit 1
fi
